{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Clairvoyance Update Descriptor",
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "$schema": { "type": "string" },
      "version": {
        "type": "string",
        "pattern": "^[0-9]+(\\.[0-9]+){1,3}$",
        "description": "Latest version number (semver)"
      },
      "minimumVersion": {
        "type": "string",
        "pattern": "^[0-9]+(\\.[0-9]+){1,3}$",
        "description": "Versions below this require a forced update"
      },
      "releaseNotes": {
        "type": "string",
        "description": "Short update summary displayed to the user"
      },
      "releaseDate": {
        "type": "string",
        "format": "date",
        "description": "Release date (ISO 8601)"
      }
    },
    "required": ["version", "minimumVersion", "releaseNotes", "releaseDate"]
  }
